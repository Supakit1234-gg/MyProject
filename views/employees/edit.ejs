<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <script src="/js/jquery-3.4.1.slim.min.js"></script>
    <script src="/js/popper.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <link rel="stylesheet" href="/css/all.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../navbar') %>

    <div class="container add-page">

        <div class="add-header">

            <div>
                <h2 class="page-title">แก้ไขข้อมูลพนักงาน</h2>
                <p class="page-subtitle">แก้ไขข้อมูลพนักงานในระบบ</p>
            </div>
        </div>

        <div class="form-card">

            <!-- Employee preview -->
            <div class="member-preview">
                <div class="member-avatar-lg" id="avatarPreview">
                    <%= employee.name.charAt(0).toUpperCase() %>
                </div>
                <div>
                    <div class="member-preview-name" id="previewName"><%= employee.name %></div>
                    <div class="member-preview-sub">
                        <span class="position-pill"><%= employee.position %></span>
                        <span class="salary-text">
             
                            <%= Number(employee.salary).toLocaleString() %> บาท
                        </span>
                    </div>
                </div>
            </div>

            <hr class="form-divider">

            <form method="POST" action="/employees/update">
                <input type="hidden" value="<%= employee._id %>" name="id">

                <!-- ชื่อ -->
                <div class="field-full">
                    <label class="field-label">ชื่อพนักงาน</label>
                    <input type="text" class="field-input" name="name"
                        value="<%= employee.name %>" placeholder="ชื่อ-นามสกุล"
                        id="nameInput">
                </div>

                <!-- เพศ + ตำแหน่ง -->
                <div class="form-row-group">
                    <div class="field-half">
                        <label class="field-label">เพศ</label>
                        <div class="select-wrap">
                            <select class="field-input field-select" name="gender">
                                <option value="">-- เลือกเพศ --</option>
                                <option value="ชาย" <%= employee.gender === 'ชาย' ? 'selected' : '' %>>ชาย</option>
                                <option value="หญิง" <%= employee.gender === 'หญิง' ? 'selected' : '' %>>หญิง</option>
                            </select>
                          
                        </div>
                    </div>
                    <div class="field-half">
                        <label class="field-label">ตำแหน่ง</label>
                        <div class="select-wrap">
                            <select class="field-input field-select" name="position">
                                <option value="">-- เลือกตำแหน่ง --</option>
                                <option value="employee" <%= employee.position === 'employee' ? 'selected' : '' %>>Employee</option>
                                <option value="manager" <%= employee.position === 'manager' ? 'selected' : '' %>>Manager</option>
                            </select>
                           
                        </div>
                    </div>
                </div>

                <!-- โทร + Email -->
                <div class="form-row-group">
                    <div class="field-half">
                        <label class="field-label">เบอร์โทร</label>
                        <input type="text" class="field-input" name="phone"
                            value="<%= employee.phone %>" placeholder="เช่น 081-234-5678">
                    </div>
                    <div class="field-half">
                        <label class="field-label">Email</label>
                        <input type="text" class="field-input" name="email"
                            value="<%= employee.email %>" placeholder="example@email.com">
                    </div>
                </div>

                <!-- เงินเดือน -->
                <div class="field-full">
                    <label class="field-label">เงินเดือน (บาท)</label>
                    <input type="text" class="field-input" name="salary"
                        value="<%= employee.salary %>" placeholder="เช่น 25000"
                        id="salaryInput">
                </div>

                <div class="form-actions">
                    <a href="/employees" class="btn-cancel">ยกเลิก</a>
                    <button type="submit" class="btn-save">
                      บันทึกการแก้ไข
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        // อัปเดต avatar และชื่อ preview เมื่อพิมพ์
        document.getElementById('nameInput').addEventListener('input', function () {
            const first = this.value.charAt(0).toUpperCase();
            document.getElementById('avatarPreview').textContent = first || '?';
            document.getElementById('previewName').textContent = this.value || '—';
        });
    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600&family=Playfair+Display:wght@500&display=swap');

        body { background: #faf8f5; font-family: 'Sarabun', sans-serif; }

        .add-page { max-width: 720px; padding: 40px 24px 60px; }

        .add-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 28px;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            padding: 8px 16px;
            background: #fff;
            border: 1.5px solid #e8e2da;
            border-radius: 10px;
            font-size: 0.88rem;
            font-weight: 600;
            color: #1a1814;
            text-decoration: none;
            white-space: nowrap;
            transition: border-color 0.2s, color 0.2s;
        }

        .btn-back:hover { border-color: #c8602a; color: #c8602a; text-decoration: none; }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            font-weight: 500;
            color: #1a1814;
            margin: 0 0 4px;
            position: relative;
            padding-bottom: 10px;
        }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0;
            width: 32px; height: 2px;
            background: #c8602a;
            border-radius: 2px;
        }

        .page-subtitle { color: #7a7570; font-size: 0.88rem; margin: 0; }

        .form-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 4px 32px rgba(0,0,0,0.08);
            padding: 32px;
        }

        /* Preview */
        .member-preview {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 4px;
        }

        .member-avatar-lg {
            width: 56px;
            height: 56px;
            background: #1a1814;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .member-preview-name {
            font-weight: 600;
            font-size: 1rem;
            color: #1a1814;
            margin-bottom: 6px;
        }

        .member-preview-sub {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .position-pill {
            background: #f0ebe4;
            color: #5a4a3a;
            border-radius: 20px;
            padding: 2px 10px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .salary-text {
            font-size: 0.82rem;
            color: #7a7570;
        }

        .form-divider {
            border: none;
            border-top: 1px solid #f0ebe4;
            margin: 20px 0 24px;
        }

        /* Fields */
        .form-row-group {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .field-half { flex: 1; }
        .field-full { margin-bottom: 20px; }

        .field-label {
            display: block;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #7a7570;
            margin-bottom: 8px;
        }

        .field-input {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid #e8e2da;
            border-radius: 10px;
            font-family: 'Sarabun', sans-serif;
            font-size: 0.95rem;
            color: #1a1814;
            background: #faf8f5;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .field-input:focus {
            outline: none;
            border-color: #c8602a;
            box-shadow: 0 0 0 3px rgba(200,96,42,0.1);
            background: #fff;
        }

        .field-input::placeholder { color: #c0b8b0; }

        .select-wrap { position: relative; }

        .field-select {
            appearance: none;
            -webkit-appearance: none;
            padding-right: 36px;
            cursor: pointer;
        }

        .select-arrow {
            position: absolute;
            right: 14px; top: 50%;
            transform: translateY(-50%);
            color: #b0a89f;
            font-size: 0.75rem;
            pointer-events: none;
        }

        /* Actions */
        .form-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 28px;
            padding-top: 24px;
            border-top: 1px solid #f0ebe4;
        }

        .btn-cancel {
            padding: 11px 24px;
            border: 1.5px solid #e8e2da;
            border-radius: 10px;
            font-family: 'Sarabun', sans-serif;
            font-size: 0.92rem;
            font-weight: 600;
            color: #fffefd;
            text-decoration: none;
            transition: border-color 0.2s, color 0.2s;
        }

        .btn-cancel:hover { border-color: #1a1814; color: #1a1814; text-decoration: none; }

        .btn-save {
            display: inline-flex;
            align-items: center;
            padding: 11px 28px;
            background: #1a1814;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Sarabun', sans-serif;
            font-size: 0.92rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            box-shadow: 0 4px 14px rgba(0,0,0,0.12);
        }

        .btn-save:hover { background: #c8602a; transform: translateY(-1px); }

        @media (max-width: 600px) {
            .form-row-group { flex-direction: column; gap: 0; }
            .form-card { padding: 24px 18px; }
            .add-page { padding: 24px 16px 48px; }
        }
    </style>

</body>
</html>