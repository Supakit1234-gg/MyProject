<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>

    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <script src="js/jquery-3.4.1.slim.min.js"></script>
    <script src="js/popper.min.js"></script>
    <script src="js/bootstrap.min.js"></script>
    <link rel="stylesheet" href="css/all.css" />

    <style>
        body {
            background: linear-gradient(135deg, #eef2ff, #f8fafc);
            font-family: 'Segoe UI', sans-serif;
        }

        /* ===== Search ===== */
        .search-form {
            background: #fff;
            padding: 24px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }

        .search-form input {
            border-radius: 10px;
        }

        .btn-search {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            color: white;
            border-radius: 10px;
            font-weight: 600;
        }

        .btn-search:hover {
            background: #4f46e5;
        }

        /* ===== Card ===== */
        .card {
            border-radius: 18px;
            overflow: hidden;
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            transition: all 0.25s ease;
            position: relative;
        }

        .card:hover {
            transform: translateY(-6px) scale(1.02);
        }

        .card-img-top {
            height: 200px;
            object-fit: cover;
        }

        .card-body {
            text-align: center;
            padding: 18px;
        }

        .card-title a {
            color: #111827;
            font-weight: 600;
            text-decoration: none;
        }

        .card-title a:hover {
            color: #6366f1;
        }

        /* ===== Badge ===== */
        .badge-stock {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 8px;
        }

        .in-stock {
            background: rgba(34,197,94,0.15);
            color: #16a34a;
        }

        .out-stock {
            background: rgba(239,68,68,0.15);
            color: #dc2626;
        }

        /* ===== SOLD OUT Overlay ===== */
        .sold-out {
            opacity: 0.65;
        }

        .sold-out::after {
            content: "SOLD OUT";
            position: absolute;
            top: 12px;
            left: 12px;
            background: #ef4444;
            color: #fff;
            padding: 6px 10px;
            font-size: 0.75rem;
            border-radius: 6px;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container mt-4">

        <!-- 🔎 Search -->
        <div class="row justify-content-center">
            <div class="col-md-8">
                <form action="/search" method="GET" class="search-form">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <input type="number" class="form-control" name="min" placeholder="ราคาต่ำสุด">
                        </div>
                        <div class="col-md-4">
                            <input type="number" class="form-control" name="max" placeholder="ราคาสูงสุด">
                        </div>
                        <div class="col-md-4 text-center">
                            <button type="submit" class="btn btn-search w-100">
                                <i class="fas fa-search"></i> ค้นหา
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- 🛍️ Products -->
        <div class="row">
            <% Object.values(products).forEach(function(item){ %>

            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card <%= item.stock === 0 ? 'sold-out' : '' %>">

                    <a href="/<%= item.id %>">
                        <img class="card-img-top"
                            src="./images/products/<%= item.image %>"
                            alt="<%= item.name %>">
                    </a>

                    <div class="card-body">

                        <h5 class="card-title">
                            <a href="/<%= item.id %>">
                                <%= item.name %>
                            </a>
                        </h5>

                        <p class="card-text">
                            <strong>ราคา:</strong> <%= item.price %> THB
                        </p>

                        <!-- ⭐ สถานะสินค้า -->
                        <% if(item.stock > 0){ %>
                            <span class="badge-stock in-stock">มีสินค้า</span>
                        <% } else { %>
                            <span class="badge-stock out-stock">สินค้าหมด</span>
                        <% } %>

                        <p class="card-text mt-2">
                            <%= item.description %>
                        </p>

                    </div>
                </div>
            </div>

            <% }) %>
        </div>
    </div>
</body>

</html>