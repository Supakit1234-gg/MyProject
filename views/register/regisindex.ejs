<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="register-wrapper">

        <!-- Brand -->
        <div class="login-brand">
            <div class="login-brand-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#c8602a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
            </div>
            <h1>K-SHOP</h1>
            <p>สร้างบัญชีใหม่เพื่อเริ่มช้อปปิ้ง</p>
        </div>

        <!-- Card -->
        <div class="register-card">

            <% if (typeof error !== "undefined") { %>
            <div class="error-msg" id="error-msg">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <%= error %>
            </div>
            <script>
                setTimeout(() => {
                    const msg = document.getElementById("error-msg");
                    if (msg) msg.remove();
                }, 10000);
            </script>
            <% } %>

            <form action="/register" method="POST">

                <!-- ชื่อ -->
                <div class="field-group">
                    <label class="field-label">ชื่อ</label>
                    <div class="field-wrap">
                        <span class="field-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#b0a89f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </span>
                        <input type="text" name="name" class="field-input"
                            placeholder="ชื่อ-นามสกุล" required
                            value="<%= old?.name || '' %>">
                    </div>
                </div>

                <!-- Email -->
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <div class="field-wrap">
                        <span class="field-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#b0a89f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>
                        <input type="email" name="email" class="field-input"
                            placeholder="example@email.com" required
                            value="<%= old?.email || '' %>">
                    </div>
                </div>

                <!-- Phone -->
                <div class="field-group">
                    <label class="field-label">เบอร์โทร</label>
                    <div class="field-wrap">
                        <span class="field-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#b0a89f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                            </svg>
                        </span>
                        <input type="text" name="phone" class="field-input"
                            placeholder="เช่น 081-234-5678" required
                            value="<%= old?.phone || '' %>">
                    </div>
                </div>

                <hr class="form-divider">

                <!-- Password -->
                <div class="field-group">
                    <label class="field-label">Password</label>
                    <div class="field-wrap">
                        <span class="field-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#b0a89f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                        </span>
                        <input type="password" name="password" id="pw1" class="field-input"
                            placeholder="รหัสผ่าน" required>
                        <button type="button" class="toggle-pw" onclick="togglePass('pw1', 'eye1')">
                            <svg id="eye1" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Confirm Password -->
                <div class="field-group">
                    <label class="field-label">ยืนยัน Password</label>
                    <div class="field-wrap">
                        <span class="field-icon">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#b0a89f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                        </span>
                        <input type="password" name="confirmPassword" id="pw2" class="field-input"
                            placeholder="ยืนยันรหัสผ่าน" required>
                        <button type="button" class="toggle-pw" onclick="togglePass('pw2', 'eye2')">
                            <svg id="eye2" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-register"
                    onclick="return confirm('ยืนยันข้อมูลการสมัครสมาชิก')">
                    สมัครสมาชิก
                </button>

            </form>
        </div>

        <div class="register-footer">
            มีบัญชีอยู่แล้ว? <a href="/login">เข้าสู่ระบบ</a>
            &nbsp;·&nbsp;
            <a href="/">กลับหน้าแรก</a>
        </div>

    </div>

    <script>
        const eyeOpen = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
        const eyeOff  = `<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>`;

        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = eyeOff;
            } else {
                input.type = 'password';
                icon.innerHTML = eyeOpen;
            }
        }
    </script>

</body>
  <style>
        @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600&family=Playfair+Display:wght@500&display=swap');

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #faf8f5;
            font-family: 'Sarabun', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 16px;
        }

        .register-wrapper {
            width: 100%;
            max-width: 460px;
            animation: fadeUp 0.45s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Brand */
        .login-brand {
            text-align: center;
            margin-bottom: 28px;
        }

        .login-brand-icon {
            width: 56px;
            height: 56px;
            background: #1a1814;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
        }

        .login-brand h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            font-weight: 500;
            color: #1a1814;
            margin-bottom: 4px;
        }

        .login-brand p { color: #7a7570; font-size: 0.88rem; }

        /* Card */
        .register-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 4px 32px rgba(0,0,0,0.08);
            padding: 36px 32px;
        }

        /*ไว้แจ้งข้อความError*/
        .error-msg {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #fdecea;
            color: #c0392b;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.88rem;
            font-weight: 500;
            margin-bottom: 20px;
            animation: fadeUp 0.3s ease both;
        }

        /* Fields */
        .form-row-group {
            display: flex;
            gap: 16px;
            margin-bottom: 0;
        }

        .field-half { flex: 1; }

        .field-group { margin-bottom: 16px; }

        .field-label {
            display: block;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #7a7570;
            margin-bottom: 7px;
        }

        .field-wrap { position: relative; }

        .field-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
            display: flex;
            align-items: center;
        }

        .field-input {
            width: 100%;
            padding: 11px 14px 11px 38px;
            border: 1.5px solid #e8e2da;
            border-radius: 10px;
            font-family: 'Sarabun', sans-serif;
            font-size: 0.95rem;
            color: #1a1814;
            background: #faf8f5;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .field-input:focus {
            outline: none;
            border-color: #c8602a;
            box-shadow: 0 0 0 3px rgba(200,96,42,0.1);
            background: #fff;
        }

        .field-input::placeholder { color: #c0b8b0; }

        .toggle-pw {
            position: absolute;
            right: 13px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            color: #b0a89f;
            transition: color 0.2s;
        }

        .toggle-pw:hover { color: #1a1814; }

        /* Divider */
        .form-divider {
            border: none;
            border-top: 1px solid #f0ebe4;
            margin: 20px 0;
        }

        /* Submit */
        .btn-register {
            width: 100%;
            padding: 13px;
            background: #1a1814;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Sarabun', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 4px 14px rgba(0,0,0,0.12);
        }

        .btn-register:hover {
            background: #c8602a;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(200,96,42,0.28);
        }

        /* Footer */
        .register-footer {
            text-align: center;
            margin-top: 18px;
            font-size: 0.88rem;
            color: #7a7570;
        }

        .register-footer a {
            color: #c8602a;
            font-weight: 600;
            text-decoration: none;
        }

        .register-footer a:hover { text-decoration: underline; }
    </style>
</html>