<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Members</title>
    <link rel="stylesheet" href="css/bootstrap.min.css" integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous" />
    <script src="js/jquery-3.4.1.slim.min.js" integrity="sha384-J6qa4849blE2+poT4WnyKhv5vZF5SrPo0iEjwBvKU7imGFAV0wwj1yYfoRSJoZ+n" crossorigin="anonymous"></script>
    <script src="js/popper.min.js" integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo" crossorigin="anonymous"></script>
    <script src="js/bootstrap.min.js" integrity="sha384-wfSDF2E50Y2D1uUdj0O3uMBJnjuUD4Ih7YwaYd1iqfktj0Uod8GCExl3Og8ifwB6" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="css/all.css" integrity="sha384-50oBUHEmvpQ+1lW4y57PTFmhCaXp0ML5d60M1M7uH2+nqUivzIebhndOJK28anvf" crossorigin="anonymous" />
    <link rel="stylesheet" href="css/style.css">
</head>

<body>
    <%- include('../navbar') %>

    <div class="container manage-page">

        <!-- Header -->
        <div class="manage-header">
            <div>
                <h2 class="page-title">จัดการสมาชิก</h2>
                <p class="page-subtitle">ลบ แก้ไขข้อมูลในฐานข้อมูล</p>
            </div>
        </div>

        <!-- Search -->
        <div class="search-wrap">
         
            <input type="text" id="searchInput" class="search-input" placeholder="ค้นหาสมาชิก...">
        </div>

        <!-- Table -->
        <div class="table-card">
            <table class="table">
                <thead>
                    <tr>
                        <th>สมาชิก</th>
                        <th>Email</th>
                        <th>เบอร์โทร</th>
                        <th colspan="2" style="text-align:center;">จัดการ</th>
                    </tr>
                </thead>
                <tbody id="memberTable">
                    <% Object.values(members).forEach(function(item){ %>
                    <tr>
                        <td>
                            <div class="member-info">
                                <div class="member-avatar">
                                    <%= item.name.charAt(0).toUpperCase() %>
                                </div>
                                <span class="name"><%= item.name %></span>
                            </div>
                        </td>
                        <td class="email"><%= item.email %></td>
                        <td class="phone">
                       
                            <%= item.phone %>
                        </td>
                        <td>
                            <a class="btn-action btn-delete"
                                href="/members/delete/<%= item._id %>"
                                onclick="return confirm('คุณต้องการลบสมาชิกนี้หรือไม่?')">
                                ลบ
                            </a>
                        </td>
                        <td>
                            <form action="/members/edit" method="POST">
                                <input type="hidden" value="<%= item._id %>" name="id">
                                <button type="submit" class="btn-action btn-edit">
                                    แก้ไข
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </div>

    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll("#memberTable tr");
            rows.forEach(row => {
                let name = row.querySelector(".name").textContent.toLowerCase();
                let email = row.querySelector(".email").textContent.toLowerCase();
                let phone = row.querySelector(".phone").textContent.toLowerCase();
                row.style.display = (name.includes(filter) || email.includes(filter) || phone.includes(filter)) ? "" : "none";
            });
        });
    </script>

    <style>
@import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600&family=Playfair+Display:wght@500&display=swap');

:root {
    --primary: #c8602a;
    --dark: #1a1814;
    --text-main: #111827;
    --text-soft: #6b7280;
    --border: #e5e7eb;
    --bg: #f9fafb;
}

/* Background */
body {
    background: var(--bg);
    font-family: 'Sarabun', sans-serif;
}

/* Layout */
.manage-page {
    padding: 40px 48px 60px;
}

/* Header */
.manage-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 24px;
}

.page-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--dark);
    position: relative;
    padding-bottom: 10px;
}

.page-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--primary);
}

.page-subtitle {
    color: var(--text-soft);
    font-size: 0.9rem;
}

/* Search */
.search-wrap {
    margin-bottom: 20px;
}

.search-input {
    width: 100%;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--text-main);
    background: #fff;
    transition: 0.2s;
}

.search-input::placeholder {
    color: #9ca3af;
}

.search-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(200,96,42,0.1);
}

/* Table Card */
.table-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    overflow: hidden;
}

/* Table */
.table {
    margin-bottom: 0;
}

.table thead tr {
    background: #f3f4f6;
}

.table thead th {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #374151;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
}

/* Table Body */
.table tbody td {
    padding: 14px 16px;
    font-size: 0.92rem;
    color: var(--text-main);
    border-bottom: 1px solid #f1f1f1;
}

.table tbody tr {
    transition: 0.2s;
}

.table tbody tr:hover {
    background: #f9fafb;
}

.table tbody tr:nth-child(even) {
    background: #fcfcfc;
}

/* Member */
.member-info {
    display: flex;
    align-items: center;
    gap: 12px;
}

.member-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
}

/* Text Detail */
.name {
    color: var(--text-main);
    font-weight: 600;
}

.email {
    color: var(--text-soft);
}

.phone {
    color: #374151;
}

/* Buttons */
.btn-action {
    padding: 7px 14px;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: 0.2s;
}

/* Delete */
.btn-delete {
    background: #fdecea;
    color: #c0392b;
}

.btn-delete:hover {
    background: #c0392b;
    color: #fff;
}

/* Edit */
.btn-edit {
    background: #e8f0fe;
    color: #2563eb;
}

.btn-edit:hover {
    background: #2563eb;
    color: #fff;
}

/* Responsive */
@media (max-width: 768px) {
    .manage-page {
        padding: 24px 16px 48px;
    }
}
    </style>

</body>
</html>